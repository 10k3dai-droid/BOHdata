# =============================================================================
# asin-tracker — Mẫu biến môi trường. Copy sang .env và điền giá trị thật.
# KHÔNG commit file .env chứa secret thật.
# =============================================================================

# ---- Keepa (crawler) --------------------------------------------------------
# API key từ tài khoản Keepa (gói €49/tháng, 20 token/phút).
KEEPA_API_KEY=your_keepa_api_key

# ---- Supabase — CRAWLER (server-side, toàn quyền, BYPASS RLS) ----------------
# Lấy ở Supabase Dashboard → Project Settings → API.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key   # service_role key — TUYỆT ĐỐI không đưa ra client/web public

# ---- Supabase — WEB ---------------------------------------------------------
# Web (Next.js) đọc/ghi data qua SERVER (service key) cho internal tool.
# Vì vậy web CŨNG cần SUPABASE_URL + SUPABASE_SERVICE_KEY ở server env (không có NEXT_PUBLIC_ → không lộ ra client).
# Hai biến NEXT_PUBLIC_* dưới đây để sẵn nếu sau này bạn bật Supabase Auth cho web.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
