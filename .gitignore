# ==== Secrets (QUAN TRỌNG — không bao giờ commit) ====
.env
.env.*
**/.env
**/.env.local
**/.env.*.local
!**/.env.example
!**/.env.local.example

# Python
crawler/.venv/
**/__pycache__/
*.pyc
crawler/logs/*.log

# Node / Next (web có .gitignore riêng, đây là backup)
web/node_modules/
web/.next/
web/out/

# OS
.DS_Store
Thumbs.db
