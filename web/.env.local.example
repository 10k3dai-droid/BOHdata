# Copy file này thành ".env.local" (cùng thư mục web/) rồi điền giá trị thật.
# Lấy ở Supabase Dashboard → Project Settings → API.

SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...service_role_key_dài...

# Tùy chọn (để dành nếu sau này bật Supabase Auth cho web):
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...anon_key...

# Tùy chọn — để "bấm Tìm trên web → chạy crawler cloud ngay" (GitHub Actions):
# GITHUB_REPO dạng "owner/name". GITHUB_DISPATCH_TOKEN = PAT có scope 'repo' (classic)
# hoặc fine-grained với quyền Actions: Read and write cho repo này.
GITHUB_REPO=10k3dBOH/BOHdata
GITHUB_DISPATCH_TOKEN=ghp_xxxxxxxxxxxxxxxx
