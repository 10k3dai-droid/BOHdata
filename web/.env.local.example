# Copy file này thành ".env.local" (cùng thư mục web/) rồi điền giá trị thật.
# Lấy ở Supabase Dashboard → Project Settings → API.

SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...service_role_key_dài...

# Tùy chọn (để dành nếu sau này bật Supabase Auth cho web):
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...anon_key...
